# ============================================================
# Ergonix Website Audit Platform — configuration
# Copy to .env and adjust. Every variable is optional; the
# defaults shown here let the platform run with zero config
# (AI analysis stays off until OPENAI_API_KEY is set).
# ============================================================

# --- Server ---
PORT=8080
LOG_LEVEL=info                 # debug | info | warn | error
DB_PATH=./data/audit.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Website registry (shown in the UI selector) ---
WEBSITES=https://ergonix.lt,https://ergonix.lv,https://ergonix.ee,https://ergonix.cz,https://ergonix.pl

# --- Crawler ---
CRAWLER_USER_AGENT=ErgonixAuditBot/1.0 (+internal site audit)
CRAWL_DELAY_MS=250             # politeness delay before every request
RESPECT_ROBOTS=true
MAX_BODY_KB=3072               # max HTML bytes read per page
SITE_CONCURRENCY=2             # websites audited in parallel
DEFAULT_MAX_PAGES=25
DEFAULT_MAX_DEPTH=3
DEFAULT_CONCURRENCY=4
DEFAULT_REQUEST_TIMEOUT_SEC=15
DEFAULT_RETRY_COUNT=2

# --- Browser checks (console errors, failed requests, real load time) ---
# Requires Playwright browsers: npx playwright install chromium
# (or use the full backend image with browsers preinstalled)
BROWSER_ENABLED=false
BROWSER_PAGES_PER_SITE=5

# --- Automatic scheduled audits ---
# When enabled, the platform audits the sites on its own on a recurring
# interval — no manual trigger needed. Each run compares against the previous
# one to surface new/resolved issues (see the "Change since audit #N" panel).
SCHEDULE_ENABLED=false
SCHEDULE_INTERVAL_HOURS=24
SCHEDULE_AT_START=false          # also run once ~5s after startup
SCHEDULE_WEBSITES=               # empty = all sites in WEBSITES

# --- AI analysis (any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_MAX_PAGES_PER_SITE=8        # richest pages are analysed first
AI_TIMEOUT_SEC=90
AI_MAX_TEXT_CHARS=4000         # visible-text budget per page summary

# --- Rule-based check thresholds ---
CHECK_LARGE_IMAGE_KB=300
CHECK_SLOW_RESPONSE_MS=1500
CHECK_SLOW_LOAD_MS=4000
CHECK_LARGE_JS_KB=500
CHECK_LARGE_CSS_KB=150
CHECK_MAX_REDIRECTS=5
LINK_PROBE_CONCURRENCY=4
LINK_PROBE_TIMEOUT_SEC=10
MAX_EXTERNAL_PROBES=100
